{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "clankerflow": ["./.clankerflow/lib/types/clankerflow.d.ts"],
      "clankerflow/helpers": ["./.clankerflow/lib/src/helpers.ts"]
    }
  },
  "include": ["workflows/**/*.ts"]
}
